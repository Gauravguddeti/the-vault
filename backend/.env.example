# ══════════════════════════════════════════════════════════════════════
#  The Vault — Backend Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ══════════════════════════════════════════════════════════════════════

# ── Database (Neon serverless Postgres) ───────────────────────────────
DATABASE_URL=postgresql://user:password@host.neon.tech/vault?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Groq LLM ──────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── OCR ───────────────────────────────────────────────────────────────
# Primary: Mistral OCR API (free tier at https://console.mistral.ai)
OCR_PROVIDER=mistral
MISTRAL_API_KEY=...

# ── Embedding ─────────────────────────────────────────────────────────
# Default: Ollama with nomic-embed-text (run: ollama pull nomic-embed-text)
EMBEDDING_PROVIDER=ollama
OLLAMA_ENDPOINT=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# For OpenAI embeddings instead (set EMBEDDING_PROVIDER=openai):
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# ── Query Tuning ──────────────────────────────────────────────────────
MIN_SIMILARITY_SCORE=0.72
MAX_CHUNKS=8
MAX_CONTEXT_TOKENS=6000

# ── AI Memory ─────────────────────────────────────────────────────────
MEMORY_WINDOW=10
MEMORY_SUMMARY_AFTER_DAYS=7

# ── File Storage ──────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Backend URL (used internally) ────────────────────────────────────
BACKEND_URL=http://localhost:8000
